.game-container {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100vh;
  background-color: #000;
}

.game-info {
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
  background-color: #333;
  color: #fff;
  font-size: 24rpx;
}

.game-canvas {
  flex: 1;
  background-color: #222;
}

.control-buttons {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background-color: #333;
}

.control-row {
  display: flex;
  justify-content: space-around;
  width: 100%;
  margin: 10rpx 0;
}

.control-button {
  width: 100rpx;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  background-color: #555;
  color: #fff;
  border-radius: 10rpx;
  font-size: 32rpx;
  margin: 0 10rpx;
}

.control-button:active {
  background-color: #777;
}