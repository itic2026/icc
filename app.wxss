/* 全局样式 */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  background-color: #000;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 40rpx;
}

.button {
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background-color: #333;
  color: #fff;
  border-radius: 10rpx;
  margin: 20rpx 0;
  font-size: 28rpx;
}

.button:active {
  background-color: #555;
}